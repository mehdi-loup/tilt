# Privy — wallet auth & embedded wallets.
# Get these at https://dashboard.privy.io/ → your app → Settings → Basics.
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Optional. If unset, the server reuses PRIVY_APP_SECRET for internal Next.js → Wayfinder sidecar calls.
WAYFINDER_INTERNAL_SECRET=
# `next dev` does NOT serve the Python function at api/wayfinder/execute.py, so
# the sidecar 404s under plain `next dev`. Either run `vercel dev` (serves it
# locally), or keep `next dev` and point this at a deployed sidecar, e.g.:
#   WAYFINDER_SIDECAR_URL=https://tilt-hazel.vercel.app/api/wayfinder/execute
# (your local PRIVY_APP_SECRET / WAYFINDER_INTERNAL_SECRET must match the
# deployment's so the x-tilt-internal-secret check passes).
WAYFINDER_SIDECAR_URL=
# Required by the Python sidecar (wayfinder-paths SDK) for balance/quote calls.
# Without it the SDK has no API key and authed calls fail.
WAYFINDER_API_KEY=
# Optional. Defaults to the live Wayfinder strategies API; override only if
# Wayfinder moves the SDK API host.
WAYFINDER_API_BASE_URL=https://strategies.wayfinder.ai/api/v1

# Required in production. Vercel KV uses KV_*; direct Upstash Redis can use
# UPSTASH_REDIS_* instead.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Optional namespace for server-wallet records.
SERVER_WALLET_REGISTRY_PREFIX=tilt:server-wallet

# Optional. Used only by scripts/stable_lender_deploy_test.py --live.
# The wallet must already hold Base USDC and at least 0.001 Base ETH.
STABLE_LENDER_TEST_WALLET_ID=
STABLE_LENDER_TEST_WALLET_ADDRESS=
STABLE_LENDER_TEST_AMOUNT_USD=2
